# =============================================================================
#  Zoiko Meet (ZoikoSema) — server environment variables
#
#  Copy this file to `.env` in the same directory and fill in real values.
#  `.env` is gitignored (never commit real secrets); this file is not — keep
#  it in sync with app/core/config.py whenever a setting is added/removed.
# =============================================================================

# ── Database (required) ──────────────────────────────────────────────────────
# Postgres connection string (SQLAlchemy + psycopg2 driver). Local dev can
# point at a local Postgres or a hosted dev instance (e.g. Supabase).
DATABASE_URL=postgresql+psycopg2://zoiko:zoiko_dev@localhost:5432/zoiko

# SQLAlchemy connection-pool sizing. Total connections per instance =
# DB_POOL_SIZE + DB_MAX_OVERFLOW. Defaults are fine for local dev; raise only
# if load-testing a large meeting.
DB_POOL_SIZE=40
DB_MAX_OVERFLOW=20

# ── Auth (required) ──────────────────────────────────────────────────────────
# Signs access tokens AND OAuth-state tokens (provider connect flow). MUST be
# a long random secret in any shared/prod environment — the dev default is
# intentionally weak and only safe on localhost.
JWT_SECRET=dev-secret-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Comma-separated emails granted /api/admin/* access. Synced to users.is_admin
# on startup — add an email here (+ restart) to grant access.
ADMIN_EMAILS=

# Comma-separated allowed CORS origins for the client dev server(s).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Rate limiting ─────────────────────────────────────────────────────────────
# Guest joins allowed per client IP per hour (blunts scripted room-flooding).
GUEST_JOIN_MAX_PER_HOUR=250

# ── Outbound email — pick ONE of Resend (preferred) or SMTP ─────────────────
# Resend transactional email. resend_from_email must be on a Resend-verified
# domain. Leave both blank to disable outbound email entirely (invites/
# reminders/RSVPs are then silently skipped, not an error).
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# SMTP fallback (used only if RESEND_API_KEY is blank).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
# Must be a real, resolvable domain — used as the .ics ORGANIZER address, so
# attendee RSVPs are delivered here.
SMTP_FROM_EMAIL=noreply@zoikosema.com
SMTP_FROM_NAME=ZoikoSema
SMTP_USE_TLS=true

# Password-reset OTP policy
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_REQUESTS_PER_HOUR=5

# ── Email branding assets ─────────────────────────────────────────────────────
# Absolute, publicly-reachable URLs (email clients block inline SVG/base64).
BRAND_EMAIL_LOGO_URL=https://meet.zoikosema.com/email-logo.png
BRAND_EMAIL_ICON_URL=https://meet.zoikosema.com/icon-192.png
BRAND_EMAIL_ASSET_BASE_URL=https://meet.zoikosema.com

# Frontend base URL — used to build invite links and OAuth-callback redirects.
FRONTEND_URL=http://localhost:5173

# ── AI ────────────────────────────────────────────────────────────────────────
# Meeting Intelligence (post-meeting summary) and Sema Calendar's AI agenda/
# brief/follow-up + mail features run on Anthropic Claude. Leave blank to
# disable them (they fail gracefully).
ANTHROPIC_API_KEY=
AI_MODEL=claude-sonnet-4-20250514

# Sema Guide (in-app support chatbot) and the post-meeting spoken-transcript
# summarizer are Groq-only — set AI_API_KEY (or GROQ_API_KEY) to enable them.
# Independent of ANTHROPIC_API_KEY/AI_PROVIDER above.
AI_API_KEY=

# ── Recordings ────────────────────────────────────────────────────────────────
# Recordings older than this are auto-deleted. Set to 0 to disable cleanup.
RECORDING_RETENTION_DAYS=30
RECORDING_CLEANUP_INTERVAL_SECONDS=3600

# ── Media plane (LiveKit) ─────────────────────────────────────────────────────
# "null" disables real media (video/audio won't connect); set "livekit" once
# a LiveKit deployment (self-hosted or Cloud) is available.
MEDIA_PROVIDER=null
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_WS_URL=
LIVEKIT_PUBLIC_WS_URL=
LIVEKIT_TOKEN_TTL_SECONDS=21600

# End-to-end encryption key for meeting audio/video/chat/captions. Falls back
# to JWT_SECRET when unset so local dev works out of the box — set a
# dedicated, unique secret in any shared/prod environment.
E2EE_SECRET=

# ── Redis (control-plane fanout + idempotency cache) ─────────────────────────
# Optional locally — most features degrade gracefully without it (e.g. the
# Action Review Queue's idempotency check just no-ops), but presence/WS
# fanout across multiple instances needs it in prod.
REDIS_URL=

# =============================================================================
#  Sema Calendar & Mail — Zoiko Connect v3
#  See architecture/SEMA_CALENDAR_MAIL_SPEC.md / _CONTEXT.md before changing.
# =============================================================================

# Fernet key encrypting provider OAuth tokens at rest (Fernet.generate_key()).
# REQUIRED for any provider-connections flow — blank fails loudly (by design)
# instead of ever storing a plaintext token.
TOKEN_VAULT_KEY=

# Google Calendar OAuth app (Google Cloud Console -> APIs & Services ->
# Credentials -> OAuth client ID -> Web application). Requests Calendar API
# scopes only — this is a SEPARATE OAuth app from Gmail below (see spec §7.3:
# each additional scope re-triggers Google's verification review, so the two
# provider integrations must not share a client id/verification track).
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:8002/api/connect/provider-connections/callback

# Microsoft Graph (Outlook Calendar) OAuth app (Azure Portal -> App
# registrations). MICROSOFT_CALENDAR_TENANT="common" accepts both personal
# Microsoft accounts and any Azure AD tenant; set a tenant GUID to restrict.
MICROSOFT_CALENDAR_CLIENT_ID=
MICROSOFT_CALENDAR_CLIENT_SECRET=
MICROSOFT_CALENDAR_REDIRECT_URI=http://localhost:8002/api/connect/provider-connections/callback
MICROSOFT_CALENDAR_TENANT=common

# Gmail OAuth app — a SEPARATE Google Cloud OAuth app from
# GOOGLE_CALENDAR_* above (see comment there). Read-only (gmail.readonly)
# until a later slice explicitly widens the scope to gmail.send.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:8002/api/connect/provider-connections/callback

# Microsoft Graph (Outlook Mail) OAuth app (Phase 3 slice 3) — a SEPARATE
# Azure AD app registration from MICROSOFT_CALENDAR_* above (same reasoning:
# Mail.Read is a materially different permission grant than Calendars.Read
# and gets its own admin-consent/review track). Read-only (Mail.Read) until
# a later slice explicitly widens the scope to Mail.Send.
MICROSOFT_MAIL_CLIENT_ID=
MICROSOFT_MAIL_CLIENT_SECRET=
MICROSOFT_MAIL_REDIRECT_URI=http://localhost:8002/api/connect/provider-connections/callback
MICROSOFT_MAIL_TENANT=common

# ZoikoTime workforce-truth availability signal (spec §6.1). Off by default —
# no real data source exists yet in this repo (separate cross-repo plan).
ZOIKOTIME_INTEGRATION_ENABLED=false
# Upgrades the signal from "visible" (Phase 1) to "enforced" (Phase 2+).
# Meaningless unless ZOIKOTIME_INTEGRATION_ENABLED is also true.
ZOIKOTIME_HARD_ENFORCEMENT_ENABLED=false
