# Postgres
POSTGRES_PASSWORD=zoiko_dev
DATABASE_URL=postgresql+psycopg2://zoiko:zoiko_dev@db:5432/zoiko

# JWT
JWT_SECRET=change-me-in-production

# CORS / Frontend
CORS_ORIGINS=http://localhost:5173,http://localhost:8080
